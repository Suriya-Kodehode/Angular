# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# For local `npm run dev` (no Docker): host is `localhost`
# For docker-compose server container: switch host to `mongo`
MONGODB_URI=mongodb://root:<password>@localhost:27017/myapp?authSource=admin
# Docker variant example:
# MONGODB_URI=mongodb://root:<password>@mongo:27017/myapp?authSource=admin

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ─── Docker Compose ───────────────────────────────────────────────────────────
# Used by docker-compose.yml to set the MongoDB root password.
# Must match the password used in MONGODB_URI above.
MONGO_ROOT_PASSWORD=
